# Web 應用設定 (web_app.py)
# DOWNLOAD_ROOT=./Photos        # 照片儲存路徑（預設為程式目錄下的 Photos/）
# PORT=5000                     # Web 伺服器連接埠
# CHROME_DEBUG_PORT=9222        # Chrome DevTools 偵錯連接埠（TikTok 搜尋用）

# SSH 隧道連線設定 (connect.py)
# SSH_HOST=your_server_ip
# SSH_PORT=22
# SSH_USER=your_username
# SSH_PASS=your_password

# 部署設定 (deploy.bat)
# 請直接編輯 deploy.bat 中的變數
